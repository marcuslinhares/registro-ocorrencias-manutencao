generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Incident {
  id               String   @id @default(auto()) @map("_id") @db.ObjectId
  machineName      String
  reason           String
  description      String
  severity         String
  typeOfOccurrence String
  isMachineStopped Boolean  @default(false)
  status           String   @default("Em Aberto")
  createdAt        DateTime @default(now())
}
